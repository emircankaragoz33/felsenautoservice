generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AppointmentStatus {
  pending
  approved
  cancelled
}

model Appointment {
  id        String            @id @default(cuid())
  name      String
  phone     String
  email     String
  plate     String
  carModel  String
  serviceType String            @default("Belirtilmedi")
  date      DateTime
  time      String
  status    AppointmentStatus @default(pending)
  reminderSentAt DateTime?
  createdAt DateTime          @default(now())

  @@unique([date, time])
  @@index([date])
  @@index([status])
}
